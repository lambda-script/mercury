{
  "name": "@lambda-script/mercury",
  "version": "2.0.0",
  "description": "Translation proxy for Claude Code - transparently translates non-English text to reduce token consumption",
  "type": "module",
  "bin": {
    "mercury": "dist/index.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "benchmark": "tsx benchmarks/multilingual.ts"
  },
  "keywords": [
    "claude",
    "anthropic",
    "translation",
    "proxy",
    "token-optimization",
    "multilingual"
  ],
  "author": "lambda-script",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lambda-script/mercury.git"
  },
  "homepage": "https://github.com/lambda-script/mercury#readme",
  "bugs": {
    "url": "https://github.com/lambda-script/mercury/issues"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.85.0",
    "franc": "^6.2.0",
    "google-translate-api-x": "^10.7.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "dotenv": "^17.4.0",
    "eslint": "^10.2.0",
    "tsup": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
